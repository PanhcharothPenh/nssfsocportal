{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "/Nssf_Resize_Logo.png",
      "dest": "/frontend/dist/Nssf_Resize_Logo.png"
    },
    {
      "src": "/favicon.svg",
      "dest": "/frontend/dist/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "/frontend/dist/icons.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
